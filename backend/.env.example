OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=INC
JIRA_ISSUE_TYPE=Bug

# Optional priority overrides if your Jira project uses different priority names
JIRA_PRIORITY_SEV_1=Highest
JIRA_PRIORITY_SEV_2=High
JIRA_PRIORITY_SEV_3=Medium

SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#incidents

SECRET_KEY=dev-secret
DATABASE_URL=sqlite:///./sentinel.db

# Background worker
SENTINEL_WORKER_ENABLED=true
SENTINEL_WORKER_POLL_SECONDS=5
SENTINEL_WORKER_WINDOW_SIZE=20
SENTINEL_WORKER_Z_THRESHOLD=3.0
